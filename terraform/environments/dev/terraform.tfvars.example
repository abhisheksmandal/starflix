# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

project     = "starflix"
environment = "dev"
aws_region  = "ap-south-1"

vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]

# true  = one shared NAT Gateway  (lower cost, no AZ-level HA — use for dev)
# false = one NAT Gateway per AZ  (higher HA — use for stage/prod)
single_nat_gateway = true

frontend_port = 80
backend_port  = 4000

owner       = "platform-team"
cost_center = "eng-infra"

s3_force_destroy = true

domain_name = "starflix.com"

enable_dns = false

enable_deletion_protection = false
secrets_recovery_window_days = 0

ecs_instance_type         = "t3.small"
ecs_ami_id                = ""
ecs_desired_capacity      = 1
ecs_min_size              = 1
ecs_max_size              = 3
enable_container_insights = false

enable_cloudfront = false
enable_waf        = false

frontend_image_tag                 = "latest"
backend_image_tag                  = "latest"
frontend_cpu                       = 256
frontend_memory                    = 512
backend_cpu                        = 256
backend_memory                     = 768
log_retention_days                 = 7
cloudwatch_cpu_threshold           = 80
cloudwatch_memory_threshold        = 80
cloudwatch_5xx_threshold           = 10
cloudwatch_response_time_threshold = 5
github_repo_url = "https://github.com/abhisheksmandal/starflix.git"
github_branch   = "main"

# GitHub PAT for CodeBuild source auth + webhook registration.
# Scopes required: repo, admin:repo_hook.
# Prefer setting via env var (TF_VAR_github_token) over committing to a file.
# Leave empty to manage the secret value out-of-band via the AWS CLI.
# github_token = "ghp_xxxxxxxxxxxxxxxxxxxx"
